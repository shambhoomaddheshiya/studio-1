rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FINANCE GROUP MANAGEMENT SYSTEM - SECURITY RULES
     * 
     * TRIGGER DEPLOYMENT: Ensuring all authenticated users (including anonymous ones)
     * have full access to the database for this prototype phase.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Relaxed rules for the prototype to allow full access to authenticated users
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}