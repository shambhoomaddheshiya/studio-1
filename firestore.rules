rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Explicitly allow authenticated access to core collections
    match /members/{docId} {
      allow read, write: if request.auth != null;
    }
    match /transactions/{docId} {
      allow read, write: if request.auth != null;
    }
    match /loans/{docId} {
      allow read, write: if request.auth != null;
    }
    match /depositEntries/{docId} {
      allow read, write: if request.auth != null;
    }
    match /repaymentEntries/{docId} {
      allow read, write: if request.auth != null;
    }

    // Fallback for all other collections
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Deployment trigger for rule propagation: 2025-02-17T15:35:00Z
  }
}