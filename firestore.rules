rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Explicitly allow access to all core collections for authenticated users
    match /members/{memberId} {
      allow read, write: if request.auth != null;
    }
    match /loans/{loanId} {
      allow read, write: if request.auth != null;
    }
    match /depositEntries/{depositEntryId} {
      allow read, write: if request.auth != null;
    }
    match /repaymentEntries/{repaymentEntryId} {
      allow read, write: if request.auth != null;
    }
    match /transactions/{transactionId} {
      allow read, write: if request.auth != null;
    }

    // Global recursive match for any other data or subcollections
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Deployment trigger for rule propagation: 2024-03-21T12:00:00Z
  }
}