
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FINANCE GROUP MANAGEMENT SYSTEM - SECURITY RULES
     * 
     * RE-DEPLOYMENT TRIGGER: Updating rules to explicitly allow authenticated access 
     * for the prototype. Timestamp: 2024-05-24T12:00:00Z
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Relaxed rules for the prototype to allow full access to all authenticated users
    // This includes users signed in anonymously.
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
