rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow any authenticated user (including anonymous guest sessions) to read and write all data.
    // This is a simplified rule for the prototyping phase to ensure all features work correctly.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Deployment trigger for rule propagation: 2025-02-17T14:45:00Z
  }
}