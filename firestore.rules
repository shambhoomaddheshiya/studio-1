rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FINANCE GROUP MANAGEMENT SYSTEM - SECURITY RULES (PROTOTYPE VERSION)
     * 
     * In this prototype phase, we allow any signed-in user to view and manage 
     * records to facilitate testing and development.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // In a real app, this would check the roles_admin collection.
      // For the prototype, we can treat any signed-in user as an admin 
      // if we want them to have full control, or keep it strict.
      // Let's keep the check but relax the collection rules below.
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isDocumentOwner(fieldName) {
      return isSignedIn() && resource != null && resource.data[fieldName] == request.auth.uid;
    }

    // --- COLLECTION RULES ---

    match /roles_admin/{userId} {
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /members/{memberId} {
      // Relaxed for prototype: any signed-in user can manage members
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /loans/{loanId} {
      allow get, list: if isSignedIn(); 
      allow create, update, delete: if isSignedIn();
    }

    match /depositEntries/{depositEntryId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /repaymentEntries/{repaymentEntryId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    match /transactions/{transactionId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }
  }
}