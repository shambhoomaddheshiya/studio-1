rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FINANCE GROUP MANAGEMENT SYSTEM - SECURITY RULES (PROTOTYPE VERSION)
     * 
     * In this prototype phase, we allow any signed-in user to view and manage 
     * all records to facilitate testing and development.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Relaxed rules for the prototype to allow full access to authenticated users
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}