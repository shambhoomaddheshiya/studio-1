rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Simplified global rule for prototyping: Allow any authenticated user full access
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Explicitly allow core collections to ensure propagation to all listeners
    match /members/{m} { allow read, write: if request.auth != null; }
    match /loans/{l} { allow read, write: if request.auth != null; }
    match /transactions/{t} { allow read, write: if request.auth != null; }
    match /depositEntries/{d} { allow read, write: if request.auth != null; }

    // Deployment trigger for rule propagation: 2025-02-17T12:30:00Z
  }
}